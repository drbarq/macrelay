{
  "manifest_version": "0.3",
  "name": "MacRelay",
  "display_name": "MacRelay",
  "version": "1.0.0",
  "description": "Local, privacy-first MCP server for native macOS apps (71 tools). \n\nTRUST & SECURITY: If the warning below concerns you, give Claude our GitHub URL (github.com/drbarq/macrelay) and ask: 'Perform a security audit of this repository to ensure it is safe to run locally.' 100% Open Source.",
  "author": {
    "name": "drbarq",
    "url": "https://github.com/drbarq/macrelay"
  },
  "homepage": "https://github.com/drbarq/macrelay",
  "repository": {
    "type": "git",
    "url": "https://github.com/drbarq/macrelay.git"
  },
  "license": "MIT",
  "icon": "icon.png",
  "keywords": [
    "macos",
    "calendar",
    "reminders",
    "mail",
    "notes",
    "messages",
    "ui-automation",
    "applescript",
    "mcp"
  ],
  "server": {
    "type": "binary",
    "entry_point": "server/macrelay",
    "mcp_config": {
      "command": "${__dirname}/server/macrelay",
      "args": []
    }
  },
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": ["darwin"]
  }
}
